---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../ui/breadcrumbs.astro";
import SkillCard from "../../ui/skill-card.astro";
import { skills, type Skill } from "../../data/skills";
import { topicBySlug } from "../../data/topics";
import type { TopicSlug } from "../../data/registry";

export function getStaticPaths() {
  const slugs = Array.from(
    new Set(skills.flatMap((skill) => skill.topics ?? [])),
  );

  return slugs.map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug ?? "";
const topic = topicBySlug.get(slug as TopicSlug);

if (!topic) {
  throw new Error(`Unknown topic: ${slug}`);
}

const relatedSkills = skills
  .filter((skill: Skill) => skill.topics?.includes(topic.slug))
  .sort((a, b) => a.pathSlug.localeCompare(b.pathSlug))
  .map((skill) => {
    const owner = skill.sourceKey ?? "ibelick";
    return {
      ...skill,
      ownerLabel: skill.sourceLabel ?? "Ibelick",
      avatarUrl: `https://github.com/${owner}.png?size=40`,
    };
  });

const breadcrumbItems = [
  { label: "Home", href: "/" },
  { label: "Topics", href: "/topics" },
  { label: topic.label },
];

const siteOrigin = Astro.site ?? new URL("https://www.ui-skills.com");
const pageUrl = new URL(`/topics/${topic.slug}`, siteOrigin).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${topic.label} Skills`,
  description: topic.description,
  url: pageUrl,
  hasPart: {
    "@type": "ItemList",
    itemListElement: relatedSkills.map((skill, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: new URL(`/skills/${skill.pathSlug}`, siteOrigin).toString(),
      name: skill.label,
    })),
  },
};
---

<Layout
  structuredData={structuredData}
  title={`${topic.label} Skills for Design Engineers | UI Skills`}
  description={`Discover ${relatedSkills.length.toLocaleString()} ${topic.label.toLowerCase()} skills for design engineering and frontend workflows.`}
>
  <div class="relative flex min-h-dvh flex-col items-center justify-start px-0 sm:px-4">
    <div class="relative mt-20 w-full max-w-3xl sm:px-0">
      <div class="mx-auto flex w-full flex-col gap-10">
        <Breadcrumbs items={breadcrumbItems} />

        <div class="px-4 sm:px-0">
          <h1 class="text-parchment-900 text-3xl font-medium tracking-tight">
            {topic.label} skills
          </h1>
          <p class="text-parchment-500 mt-3 text-[15px]">
            {topic.description}
          </p>
        </div>

        <div class="grid gap-4 px-4 sm:grid-cols-2 lg:grid-cols-3 sm:px-0">
          {
            relatedSkills.map((skill) => (
              <SkillCard
                href={`/skills/${skill.pathSlug}`}
                slug={skill.slug}
                description={skill.description}
                ownerLabel={skill.ownerLabel}
                avatarUrl={skill.avatarUrl}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Layout>
